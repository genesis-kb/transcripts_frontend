# ===========================================
# Bitcoin Transcripts Backend - Environment Variables
# ===========================================
# Copy this file to .env and fill in the values

# Server Configuration
NODE_ENV=development
PORT=5000

# Database Configuration (AWS RDS PostgreSQL)
DATABASE_URL=postgresql://user:password@your-rds-endpoint.region.rds.amazonaws.com:5432/postgres
DB_POOL_MAX=10
DB_IDLE_TIMEOUT_MS=30000
DB_CONNECT_TIMEOUT_MS=30000
DB_STATEMENT_TIMEOUT_MS=15000
DB_QUERY_TIMEOUT_MS=20000
DB_MAX_RETRIES=1
DB_RETRY_DELAY_MS=250

# Gemini AI Configuration
# Get this from: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your-gemini-api-key-here

# CORS Configuration
# Comma-separated list of allowed origins (no spaces)
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# Rate Limiting
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=100

# Logging
LOG_LEVEL=info

# Admin API (required for admin backend)
ADMIN_PASSWORD=change-this-admin-password
ADMIN_JWT_SECRET=change-this-long-random-secret
ADMIN_TOKEN_TTL=8h
ADMIN_RATE_LIMIT_WINDOW_MS=60000
ADMIN_RATE_LIMIT_MAX_REQUESTS=60
